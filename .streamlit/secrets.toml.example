# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml and fill in your actual credentials.
# IMPORTANT: Never commit the real secrets.toml to version control!

[secrets]
MONGODB_URI = "mongodb+srv://your_user:your_pass@your_cluster.mongodb.net/farmos"
OPENWEATHER_KEY = "your_openweather_api_key_here"
GEE_PROJECT = "your_gee_project_id"

TWILIO_SID = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_TOKEN = "your_twilio_auth_token_here"
TWILIO_FROM = "+1xxxxxxxxxx"
FARMER_PHONE = "+91xxxxxxxxxx"
